generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User {
  id                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                       String                    @db.VarChar(150)
  email                      String                    @unique @db.VarChar(255)
  password_hash              String
  mobile                     String                    @unique @db.VarChar(15)
  referer_code               String?                   @unique @db.VarChar(50)
  is_active                  Boolean                   @default(true)
  user_type                  UserType                  @default(NORMAL)
  created_at                 DateTime                  @default(now()) @db.Timestamp(6)
  updated_at                 DateTime                  @default(now()) @db.Timestamp(6)
  referred_by                String?                   @db.VarChar(50)
  commission_rate            Decimal?                  @db.Decimal(5, 2)
  franchise_address          String?                   @db.VarChar(500)
  franchise_city             String?                   @db.VarChar(100)
  franchise_pincode          String?                   @db.VarChar(10)
  franchise_state            String?                   @db.VarChar(100)
  franchise_type             FranchiseType?            @default(DIRECT_SELLER)
  assigned_rates             Json?
  wallet_balance             Decimal                   @default(0) @db.Decimal(12, 2)
  max_commission_rate        Decimal?                  @db.Decimal(5, 2)
  min_commission_rate        Decimal?                  @db.Decimal(5, 2)
  aadhaar_number             String?                   @db.VarChar(12)
  aadhaar_verified           Boolean                   @default(false)
  gst_number                 String?                   @db.VarChar(15)
  gst_verified               Boolean                   @default(false)
  kyc_status                 KycStatus                 @default(PENDING)
  pan_number                 String?                   @db.VarChar(10)
  pan_verified               Boolean                   @default(false)
  active_discount            Decimal                   @default(0) @db.Decimal(5, 2)
  security_deposit           Decimal                   @default(0) @db.Decimal(12, 2)
  upi_id                     String?                   @db.VarChar(100)
  bank_name                  String?                   @db.VarChar(100)
  beneficiary_name           String?                   @db.VarChar(150)
  account_number            String?                   @db.VarChar(25)
  ifsc_code                  String?                   @db.VarChar(15)
  default_referred_pickup_id String?                   @db.Uuid
  addresses                  Address[]
  withdrawals                CommissionWithdrawal[]
  feedbacks                  Feedback[]
  referral_commissions       OrderReferralCommission[]
  orders                     Order[]
  rto_disputes               RTODispute[]
  support_tickets            SupportTicket[]
  transactions               Transaction[]
  user_login_history         UserLoginHistory[]
  weight_disputes            WeightDispute[]
  security_deposits         SecurityDeposit[]

  @@map("users")
}

model WalletPlan {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(100)
  recharge_amount     Decimal  @db.Decimal(10, 2)
  discount_percentage Decimal  @db.Decimal(5, 2)
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamp(6)
  updated_at          DateTime @default(now()) @db.Timestamp(6)

  @@map("wallet_plans")
}

model Transaction {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String              @db.Uuid
  amount        Decimal             @db.Decimal(12, 2)
  closing_balance Decimal?          @db.Decimal(12, 2)
  type          TransactionType
  status        TransactionStatus   @default(PENDING)
  description   String?             @db.VarChar(255)
  reference_id  String?             @db.VarChar(100)
  created_at    DateTime            @default(now()) @db.Timestamp(6)
  updated_at    DateTime            @default(now()) @db.Timestamp(6)
  category      TransactionCategory @default(WALLET_TOPUP)
  status_reason String?             @db.VarChar(500)
  user          User                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model SystemSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(50)
  value       String
  description String?  @db.VarChar(255)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  @@map("system_settings")
}

model SecurityRefundSchedule {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduled_date    DateTime  @db.Timestamp(6)
  is_active         Boolean   @default(true)
  last_triggered_at DateTime? @db.Timestamp(6)
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  updated_at        DateTime  @default(now()) @db.Timestamp(6)

  @@map("security_refund_schedule")
}

model SecurityDeposit {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  order_id    BigInt
  amount      Decimal   @db.Decimal(12, 2)
  used_amount Decimal   @db.Decimal(12, 2) @default(0)
  remaining   Decimal   @db.Decimal(12, 2)
  status      String    @default("ACTIVE") @db.VarChar(20)
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @db.Timestamp(6)

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([order_id])
  @@map("security_deposits")
}

model Address {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String   @db.Uuid
  complete_address     String
  city                 String   @db.VarChar(100)
  state                String   @db.VarChar(100)
  pincode              String   @db.VarChar(10)
  is_default           Boolean? @default(false)
  created_at           DateTime @default(now()) @db.Timestamp(6)
  updated_at           DateTime @default(now()) @db.Timestamp(6)
  address_label        String?  @db.VarChar(50)
  country              String   @default("India") @db.VarChar(100)
  email                String?  @db.VarChar(255)
  name                 String   @db.VarChar(150)
  phone                String   @db.VarChar(15)
  is_shiprocket_pickup Boolean? @default(false)
  pickup_nickname      String?  @db.VarChar(50)
  phone_verified       Boolean? @default(false)
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model UserLoginHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  ip_address   String?  @db.Inet
  device_info  String?
  user_agent   String?
  login_status String   @db.VarChar(20)
  login_at     DateTime @default(now()) @db.Timestamp(6)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_login_history")
}

model Order {
  id                          BigInt                    @id @default(autoincrement())
  user_id                     String                    @db.Uuid
  order_type                  OrderType
  shipment_status             ShipmentStatus            @default(PENDING)
  shipment_type               ShipmentType
  payment_mode                PaymentMode
  total_amount                Decimal                   @db.Decimal(12, 2)
  created_at                  DateTime                  @default(now()) @db.Timestamp(6)
  updated_at                  DateTime                  @default(now()) @db.Timestamp(6)
  delivered_at                DateTime?                 @db.Timestamp(6)
  weight                      Decimal?                  @db.Decimal(10, 2)
  courier_id                  Int?
  courier_name                String?                   @db.VarChar(100)
  shipping_charge             Decimal?                  @db.Decimal(12, 2)
  base_shipping_charge        Decimal?                  @db.Decimal(12, 2)
  franchise_commission_amount Decimal?                  @db.Decimal(12, 2)
  franchise_commission_rate   Decimal?                  @db.Decimal(5, 2)
  global_commission_amount    Decimal?                  @db.Decimal(12, 2)
  global_commission_rate      Decimal?                  @db.Decimal(5, 2)
  height                      Decimal?                  @db.Decimal(10, 2)
  length                      Decimal?                  @db.Decimal(10, 2)
  width                       Decimal?                  @db.Decimal(10, 2)
  product_amount              Decimal?                  @db.Decimal(12, 2)
  is_franchise_withdrawn      Boolean                   @default(false)
  label_url                   String?
  manifest_url                String?
  rto_charges                 Decimal?                  @db.Decimal(12, 2)
  rto_label_url               String?
  shiprocket_order_id         String?                   @db.VarChar(50)
  shiprocket_shipment_id      String?                   @db.VarChar(50)
  track_url                   String?
  tracking_number             String?                   @db.VarChar(100)
  cod_amount                  Decimal?                  @db.Decimal(12, 2)
  manifest_generated_at       DateTime?                 @db.Timestamp(6)
  products                    Json?
  remittance_id               String?                   @db.VarChar(100)
  remittance_ref_id           String?                   @db.VarChar(100)
  remittance_status           RemittanceStatus          @default(NOT_APPLICABLE)
  remitted_amount             Decimal?                  @db.Decimal(12, 2)
  remitted_at                 DateTime?                 @db.Timestamp(6)
  is_draft                    Boolean                   @default(false)
  is_vyom                     Boolean                   @default(false)
  payout_status               PayoutStatus              @default(PENDING)
  vyom_order_id               String?                   @db.VarChar(50)
  vyom_shipment_id            String?                   @db.VarChar(50)
  pickup_scheduled_date       DateTime?                 @db.Timestamp(6)
  pickup_location             String?                   @db.VarChar(255)
  etd                         String?                   @db.VarChar(50)
  order_pickup_address        OrderPickupAddress?
  order_receiver_address      OrderReceiverAddress?
  referral_commissions        OrderReferralCommission[]
  user                        User                      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rto_dispute                 RTODispute?
  shipment_history            ShipmentHistory[]
  weight_dispute              WeightDispute?
  security_deposits          SecurityDeposit[]

  @@map("orders")
}

model OrderPickupAddress {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id BigInt  @unique
  name     String  @db.VarChar(150)
  phone    String  @db.VarChar(15)
  email    String? @db.VarChar(255)
  address  String
  city     String  @db.VarChar(100)
  state    String  @db.VarChar(100)
  pincode  String  @db.VarChar(10)
  country  String  @default("India") @db.VarChar(100)
  order    Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_pickup_addresses")
}

model OrderReceiverAddress {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id BigInt  @unique
  name     String  @db.VarChar(150)
  phone    String  @db.VarChar(15)
  email    String? @db.VarChar(255)
  address  String
  city     String  @db.VarChar(100)
  state    String  @db.VarChar(100)
  pincode  String  @db.VarChar(10)
  country  String  @default("India") @db.VarChar(100)
  order    Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_receiver_addresses")
}

model CommissionWithdrawal {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String           @db.Uuid
  amount          Decimal          @db.Decimal(12, 2)
  status          WithdrawalStatus @default(PENDING)
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @db.Timestamp(6)
  franchise_id    String?          @db.Uuid
  reference_id    String?          @db.VarChar(100)
  payment_method String?          @db.VarChar(20)
  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("commission_withdrawals")
}

model ReferralLevelSetting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  max_levels Int
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@map("referral_level_settings")
}

model OrderReferralCommission {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     BigInt
  level        Int
  referrer_id  String    @db.Uuid
  amount       Decimal   @db.Decimal(12, 2)
  is_withdrawn Boolean   @default(false)
  withdrawn_at DateTime?
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
  order        Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  referrer     User      @relation(fields: [referrer_id], references: [id], onDelete: Cascade)

  @@unique([order_id, level])
  @@map("order_referral_commissions")
}

model ShipmentHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        BigInt
  status          String   @db.VarChar(50)
  status_date     DateTime @db.Timestamp(6)
  location        String?  @db.VarChar(200)
  shipment_status String?  @db.VarChar(50)
  activity        String?  @db.VarChar(255)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  order           Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("shipment_history")
}

model SupportTicket {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String              @db.Uuid
  subject    String              @db.VarChar(255)
  message    String
  status     SupportTicketStatus @default(OPEN)
  created_at DateTime            @default(now()) @db.Timestamp(6)
  updated_at DateTime            @default(now()) @db.Timestamp(6)
  user       User                @relation(fields: [user_id], references: [id])

  @@map("support_tickets")
}

model WeightDispute {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id                BigInt        @unique
  user_id                 String        @db.Uuid
  applied_weight          Decimal       @db.Decimal(10, 3)
  charged_weight          Decimal       @db.Decimal(10, 3)
  applied_amount          Decimal       @db.Decimal(12, 2)
  charged_amount          Decimal       @db.Decimal(12, 2)
  difference_amount       Decimal       @db.Decimal(12, 2)
  status                  DisputeStatus @default(PENDING)
  action_reason           String?
  created_at              DateTime      @default(now()) @db.Timestamp(6)
  updated_at              DateTime      @default(now()) @db.Timestamp(6)
  discrepancy_description String?
  packed_box_image        String?
  product_category        String?       @db.VarChar(100)
  weight_scale_image      String?
  order                   Order         @relation(fields: [order_id], references: [id])
  user                    User          @relation(fields: [user_id], references: [id])

  @@map("weight_disputes")
}

model RTODispute {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id      BigInt        @unique
  user_id       String        @db.Uuid
  reason        String
  status        DisputeStatus @default(PENDING)
  action_reason String?
  rto_awb       String?       @db.VarChar(50)
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  updated_at    DateTime      @default(now()) @db.Timestamp(6)
  order         Order         @relation(fields: [order_id], references: [id])
  user          User          @relation(fields: [user_id], references: [id])

  @@map("rto_disputes")
}

model Feedback {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  subject    String   @db.VarChar(255)
  message    String
  type       String   @default("FEEDBACK")
  created_at DateTime @default(now()) @db.Timestamp(6)
  user       User     @relation(fields: [user_id], references: [id])

  @@map("feedbacks")
}

model OtpVerification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @db.VarChar(255)
  mobile     String?  @db.VarChar(15)
  otp_code   String   @db.VarChar(6)
  purpose    String   @db.VarChar(50)
  expires_at DateTime @db.Timestamp(6)
  verified   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([email, purpose])
  @@index([mobile, purpose])
  @@map("otp_verifications")
}

model TempRegistrationData {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String         @unique @db.VarChar(255)
  name              String         @db.VarChar(150)
  mobile            String         @db.VarChar(15)
  password_hash     String
  referred_by       String?        @db.VarChar(50)
  franchise_type    FranchiseType?
  franchise_address String?        @db.VarChar(500)
  franchise_pincode String?        @db.VarChar(10)
  franchise_city    String?        @db.VarChar(100)
  franchise_state   String?        @db.VarChar(100)
  commission_rate   Decimal?       @db.Decimal(5, 2)
  created_at        DateTime       @default(now()) @db.Timestamp(6)

  @@map("temp_registration_data")
}

model CourierConfiguration {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courier_company_id Int      @unique
  custom_tag         String?  @db.VarChar(100)
  is_vyom            Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @default(now()) @db.Timestamp(6)

  @@map("courier_configurations")
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionCategory {
  WALLET_TOPUP
  ORDER_PAYMENT
  REFUND
  COD_REMITTANCE
  COMMISSION
  SECURITY_DEPOSIT
  WEIGHT_DISPUTE
  RTO_CHARGE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum UserType {
  ADMIN
  NORMAL
}

enum PayoutStatus {
  PENDING
  COMPLETED
}

enum OrderType {
  SURFACE
  EXPRESS
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  MANIFESTED
  OUT_FOR_PICKUP
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DISPATCHED
  DELIVERED
  NOT_PICKED
  CANCELLED
  RTO
  RTO_DELIVERED
  DRAFT
}

enum ShipmentType {
  DOMESTIC
  INTERNATIONAL
}

enum PaymentMode {
  PREPAID
  COD
}

enum RemittanceStatus {
  NOT_APPLICABLE
  PENDING
  PROCESSING
  REMITTED
  FAILED
}

enum FranchiseType {
  DIRECT_SELLER
  DISTRIBUTOR
  PARTNER
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DisputeStatus {
  PENDING
  ACCEPTED
  REJECTED
}


